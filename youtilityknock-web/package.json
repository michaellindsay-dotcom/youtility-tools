{
  "name": "youtilityknock-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "YoutilityKnock — door-to-door canvassing dashboard (web + iOS + Android) on Firebase.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:native": "tsc --noEmit && VITE_NATIVE=1 VITE_API_BASE=https://youtilityknock.web.app/api vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "cap:sync": "npm run build:native && cap sync",
    "cap:ios": "npm run build:native && cap sync ios && cap open ios",
    "cap:android": "npm run build:native && cap sync android && cap open android",
    "assets:generate": "capacitor-assets generate --iconBackgroundColor '#0ea5e9' --iconBackgroundColorDark '#0f1727' --splashBackgroundColor '#0f1727' --splashBackgroundColorDark '#0f1727'",
    "emulators": "firebase emulators:start",
    "deploy": "npm run build && firebase deploy"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^6.3.1",
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.1.2",
    "@capacitor/geolocation": "^6.0.1",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.3",
    "firebase": "^10.13.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "@types/leaflet": "^1.9.12",
    "@types/leaflet.markercluster": "^1.5.4",
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.6"
  }
}
