{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "predeploy": ["npm --prefix \"$PROJECT_DIR\" run build"],
    "rewrites": [
      { "source": "/api/**", "function": "api" },
      { "source": "/demo-request", "function": "requestDemo" },
      { "source": "/stripe/**", "function": "stripeWebhook" },
      { "source": "/square/**", "function": "squareWebhook" },
      { "source": "/sign-api/**", "function": "invoiceSign" },
      { "source": "/crm/**", "function": "crmApi" },
      { "source": "/app/**", "destination": "/app/index.html" }
    ],
    "headers": [
      {
        "source": "/app/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ],
    "cleanUrls": true
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "canvasspro-web/functions",
    "runtime": "nodejs22",
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  },
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true }
  }
}
