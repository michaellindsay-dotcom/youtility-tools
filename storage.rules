rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Chat image uploads: any signed-in user, images only, under 8 MB.
    match /chat/{companyId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Lead photos (front of home, utility bill): signed-in, images only, <12 MB.
    match /leads/{companyId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 12 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Reward images (admin-uploaded incentives): signed-in, images only, <8 MB.
    match /rewards/{companyId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
