rules_version = '2';
// ============================================================================
// YoutilityKnock — multi-tenant rules with per-company role hierarchy and
// DOWNSTREAM-only visibility.
//
// Access tiers: superadmin > admin (company) > manager > user.
//   • superadmin = platform operator (custom claim superAdmin:true). Sees and
//     acts across every company (this is what powers super-admin "mirror").
//   • admin      = company admin; full access within their own company.
//   • manager    = sees only their DOWNSTREAM (their reports and below), via
//                  membership in a doc's managerPath / visibilityPath.
//   • user       = leaf; sees only their own records.
//
// Custom company roles (companies/{id}/roles) are TITLES mapped onto a base
// tier (manager|user); they never grant admin/superadmin.
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    function isSuper()    { return isSignedIn() && request.auth.token.superAdmin == true; }
    function me()         { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function myCompany()  { return isSignedIn() ? me().companyId : null; }
    function myRole()     { return isSignedIn() ? me().role : 'none'; }
    function isCompanyAdmin()  { return myRole() == 'admin'; }
    function isManagerOrAdmin() { return myRole() == 'admin' || myRole() == 'manager'; }
    function inMyCompany(cid) { return isSuper() || (isSignedIn() && cid == myCompany()); }
    // Caller can see a record whose owner-chain is `path` (owner + ancestors).
    function inPath(path) { return isSignedIn() && (request.auth.uid in path); }

    // ── companies (tenants) + per-company roles & teams ──────────────────
    // Invoices: super-admins see all; a company's admins see their own. Written
    // only by Cloud Functions (mirrored from Stripe).
    match /invoices/{invoiceId} {
      allow read: if isSuper()
                  || (isSignedIn() && resource.data.companyId == myCompany() && isCompanyAdmin());
      allow write: if false;
    }

    match /companies/{companyId} {
      allow read: if isSuper() || (isSignedIn() && companyId == myCompany());
      allow write: if false; // server-side only (Cloud Functions)

      // Role catalog + teams: any company member may read (to render titles /
      // team names); only Cloud Functions (company admin / super) may write.
      match /roles/{roleId} {
        allow read: if inMyCompany(companyId);
        allow write: if false;
      }
      match /teams/{teamId} {
        allow read: if inMyCompany(companyId);
        allow write: if false;
      }

      // Rewards: any company member reads (to see the store); company admins
      // (or super) create/edit/remove them directly.
      match /rewards/{rewardId} {
        allow read: if inMyCompany(companyId);
        allow write: if isSuper() || (isSignedIn() && companyId == myCompany() && isCompanyAdmin());
      }

      // Weekly-recap snapshot state — Cloud Functions only.
      match /recap/{docId} {
        allow read, write: if false;
      }

      // Lead outreach automation rules: any company member reads (to see what's
      // configured); company admins (or super) create/edit/remove them. Actually
      // sending/enqueuing is Cloud-Functions-only (see outreachQueue below).
      match /outreachRules/{ruleId} {
        allow read: if inMyCompany(companyId);
        allow write: if isSuper() || (isSignedIn() && companyId == myCompany() && isCompanyAdmin());
      }
    }

    // ── outreach queue (scheduled automated sends) — Cloud Functions only ────
    match /outreachQueue/{queueId} {
      allow read, write: if false;
    }

    // ── SMS conversation log (rep text inbox) ────────────────────────────
    // The owning rep and their company admin/super-admin can read; all writes
    // (sending + inbound logging) go through Cloud Functions.
    match /smsMessages/{msgId} {
      allow read: if isSuper()
                  || (isSignedIn() && resource.data.repUid == request.auth.uid)
                  || (isSignedIn() && resource.data.companyId == myCompany() && isCompanyAdmin());
      allow write: if false;
    }

    // ── SMS opt-out suppression list (TCPA) — Cloud Functions only ───────
    match /smsSuppressions/{phone} {
      allow read, write: if false;
    }

    // ── organizations (parent grouping over companies) ───────────────────
    // Managed entirely from the super-admin console; written by Cloud
    // Functions only. Holds org-level billing settings + lock state.
    match /organizations/{orgId} {
      allow read: if isSuper();
      allow write: if false;
    }

    // ── pitch recordings (rep audio + AI coaching) ───────────────────────
    // A rep creates their own pitch doc; they and their managers/admins read
    // it. The AI pipeline (Cloud Functions) writes the transcript + feedback.
    match /pitches/{pitchId} {
      allow read: if (isSignedIn() && resource.data.uid == request.auth.uid)
                  || (inMyCompany(resource.data.companyId)
                      && (isSuper() || isCompanyAdmin() || inPath(resource.data.visibilityPath)));
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.companyId == myCompany();
      allow update, delete: if false; // server-side only (AI pipeline / retention)
    }

    // ── reward redemptions (a rep claims a reward) ───────────────────────
    match /redemptions/{redemptionId} {
      allow read: if isSuper()
                  || (isSignedIn() && resource.data.companyId == myCompany()
                      && (isCompanyAdmin() || resource.data.userId == request.auth.uid));
      allow create: if isSignedIn()
                    && request.resource.data.companyId == myCompany()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSuper()
                    || (isSignedIn() && resource.data.companyId == myCompany() && isCompanyAdmin());
    }

    // ── users (accounts + hierarchy) ─────────────────────────────────────
    // Own doc always; company admins see the whole company; managers see only
    // their downstream (their uid in the target's managerPath). All writes go
    // through Cloud Functions.
    match /users/{userId} {
      allow read: if isSuper()
                  || (isSignedIn() && request.auth.uid == userId)
                  || (isSignedIn() && resource.data.companyId == myCompany()
                      && (isCompanyAdmin() || request.auth.uid in resource.data.managerPath));
      allow write: if false; // server-side only (Cloud Functions)
    }

    // ── leads (downstream-scoped) ────────────────────────────────────────
    match /leads/{leadId} {
      allow read: if (isSignedIn() && resource.data.assignedTo == request.auth.uid)
                  || (inMyCompany(resource.data.companyId)
                      && (isSuper() || isCompanyAdmin() || inPath(resource.data.visibilityPath)));
      allow create: if isSignedIn()
                    && request.resource.data.companyId == myCompany()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.auth.uid in request.resource.data.visibilityPath;
      allow update: if inMyCompany(resource.data.companyId)
                    && (isSuper() || isCompanyAdmin() || inPath(resource.data.visibilityPath))
                    && request.resource.data.companyId == resource.data.companyId
                    // Only company admins (or super) may archive/restore a lead
                    // (toggle the `deleted` flag). Everyone else's updates must
                    // leave it unchanged.
                    && (request.resource.data.get('deleted', false) == resource.data.get('deleted', false)
                        || isSuper() || isCompanyAdmin());
      // Leads are never hard-deleted — deletion is a soft archive (an update
      // that sets `deleted`, gated to admins above).
      allow delete: if false;
    }

    // ── shifts (downstream-scoped, same visibilityPath pattern) ──────────
    match /shifts/{shiftId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid)
                  || (inMyCompany(resource.data.companyId)
                      && (isSuper() || isCompanyAdmin() || inPath(resource.data.visibilityPath)));
      allow create: if isSignedIn()
                    && request.resource.data.companyId == myCompany()
                    && request.auth.uid in request.resource.data.visibilityPath;
      allow update, delete: if inMyCompany(resource.data.companyId)
                    && (isSuper() || isCompanyAdmin() || inPath(resource.data.visibilityPath));
    }

    // ── challenges (rep-vs-rep Throw Downs) ──────────────────────────────
    // Participants (and company admins) may read; all writes go through the
    // create/respond/tick Cloud Functions (admin SDK), so clients never write.
    match /challenges/{challengeId} {
      allow read: if inMyCompany(resource.data.companyId)
                  && (isSuper() || isCompanyAdmin() || request.auth.uid in resource.data.participants);
      allow create, update, delete: if false;
    }

    // ── user stats ───────────────────────────────────────────────────────
    // Any company member can read their company's stats (powers a company-wide
    // leaderboard everyone can see). A user writes only their own.
    match /userStats/{userId} {
      allow read: if isSuper()
                  || (isSignedIn() && request.auth.uid == userId)
                  || (isSignedIn() && resource.data.companyId == myCompany());
      allow write: if isSignedIn()
                   && (request.auth.uid == userId || isSuper());
    }

    // ── season stats (resetting week/month/year buckets) ─────────────────
    // Company-wide readable (leaderboard); a user writes only their own.
    match /seasonStats/{docId} {
      allow read: if isSuper()
                  || (isSignedIn() && resource.data.uid == request.auth.uid)
                  || (isSignedIn() && resource.data.companyId == myCompany());
      allow write: if isSignedIn()
                   && (request.resource.data.uid == request.auth.uid || isSuper());
    }

    // ── territories (company-wide) ───────────────────────────────────────
    match /territories/{territoryId} {
      allow read: if inMyCompany(resource.data.companyId);
      allow create: if isSignedIn()
                    && request.resource.data.companyId == myCompany()
                    && isManagerOrAdmin();
      allow update, delete: if inMyCompany(resource.data.companyId) && isManagerOrAdmin();
    }

    // ── battery proposals (closer tool) ──────────────────────────────────
    // Created by the closer; visible to them and everyone in their
    // visibilityPath (managers + admins). Owner or a manager may edit.
    match /proposals/{proposalId} {
      allow read: if isSuper()
                  || (inMyCompany(resource.data.companyId)
                      && (isManagerOrAdmin() || inPath(resource.data.visibilityPath)));
      allow create: if isSignedIn()
                    && request.resource.data.companyId == myCompany()
                    && request.resource.data.closerUid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.companyId == myCompany()
                    && (resource.data.closerUid == request.auth.uid || isManagerOrAdmin());
      allow delete: if isSignedIn() && resource.data.companyId == myCompany()
                    && (resource.data.closerUid == request.auth.uid || isCompanyAdmin());
    }

    // ── lookups (audit) ──────────────────────────────────────────────────
    match /lookups/{lookupId} {
      allow read: if inMyCompany(resource.data.companyId)
                  && (isSuper() || isManagerOrAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.companyId == myCompany()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSuper();
    }

    // ── impersonation audit log (super-admin mirror) ─────────────────────
    match /impersonationLogs/{logId} {
      allow read: if isSuper();
      allow write: if false; // written by Cloud Functions only
    }

    // ── team chat (company channel) ──────────────────────────────────────
    match /chat/{messageId} {
      allow read: if inMyCompany(resource.data.companyId);
      allow create: if isSignedIn()
                    && request.resource.data.companyId == myCompany()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isCompanyAdmin() || isSuper());
    }

    // ── direct messages ──────────────────────────────────────────────────
    match /dms/{channelId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/dms/$(channelId)).data.members;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/dms/$(channelId)).data.members;
      }
    }

    // ── scheduled events (appointments / go-backs / follow-ups) ──────────
    match /events/{eventId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid)
                  || (inMyCompany(resource.data.companyId)
                      && (isSuper() || isCompanyAdmin() || inPath(resource.data.visibilityPath)));
      allow create: if isSignedIn()
                    && request.resource.data.companyId == myCompany()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isManagerOrAdmin());
    }

    // ── in-app notifications ─────────────────────────────────────────────
    // Mostly written by Cloud Functions, but a user may create their OWN
    // notification (e.g. a client-detected reward unlock). It only ever
    // affects their own bell.
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // ── presence (online heartbeat) ──────────────────────────────────────
    match /presence/{uid} {
      // Presence now carries live location — scope reads to the same company
      // (legacy docs without a companyId stay readable, they hold only lastSeen).
      allow read: if isSignedIn()
                  && (resource.data.get('companyId', null) == null
                      || isSuper() || resource.data.get('companyId', null) == myCompany());
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── subscription plans / pricing tiers (super-admin defines) ─────────
    // Readable by any signed-in user (to show plan features); only the
    // super-admin writes them.
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isSuper();
    }

    // ── platform config (notification + integration keys) ────────────────
    // Holds secrets (SendGrid/Twilio, OAuth client secrets). Cloud Functions
    // only — never exposed to any client. Consoles read/write via callables
    // that mask the secrets.
    match /config/{docId} {
      allow read, write: if false;
    }

    // ── calendar OAuth refresh tokens (per user) ─────────────────────────
    // Highly sensitive. Cloud Functions only.
    match /calendarTokens/{uid} {
      allow read, write: if false;
    }

    // ── demo requests (public landing-page form) ─────────────────────────
    // Created server-side only (requestDemo Cloud Function, which also emails
    // every super-admin). Super-admins read them in the console and may update
    // one (e.g. mark it handled) or delete it. No client writes here directly,
    // so the public form can't be used to spam Firestore.
    match /demoRequests/{requestId} {
      allow read, update, delete: if isSuper();
      allow create: if false;
    }

    // ── per-company YoutilityCRM link (holds each tenant's CRM secret) ───
    // Cloud Functions only. Consoles read/write via getCompanyCrm/
    // setCompanyCrm callables, which mask the secret.
    match /crmLinks/{companyId} {
      allow read, write: if false;
    }
  }
}
