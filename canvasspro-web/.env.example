# Firebase web app config — copy to `.env` and fill in from the Firebase
# console (Project settings → General → Your apps → Web app → SDK config).
# These are public client identifiers (safe to ship in the bundle); access is
# controlled by Firestore security rules and Auth, NOT by hiding these.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=youtilityknock.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=youtilityknock
VITE_FIREBASE_STORAGE_BUCKET=youtilityknock.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# When "1", the app connects to local Firebase emulators (see `npm run emulators`).
VITE_USE_EMULATORS=0

# Base path for the Knockstat proxy Cloud Function. In production this is the
# Hosting rewrite "/api". For local emulator use the functions emulator URL.
VITE_API_BASE=/api
