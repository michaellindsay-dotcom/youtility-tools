rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- helpers ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function role() {
      return isSignedIn() ? userDoc().role : 'none';
    }
    function isAdmin() {
      return role() == 'admin';
    }
    function isManagerOrAdmin() {
      return role() == 'admin' || role() == 'manager';
    }

    // --- users -----------------------------------------------------------
    // A user can read their own profile; managers/admins can read all.
    // Role changes are NOT allowed from the client — only Cloud Functions
    // (admin SDK) may set a user's role. See functions/src/index.ts.
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isManagerOrAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId
                    && request.resource.data.role == 'rep';
      allow update: if isSignedIn() && request.auth.uid == userId
                    && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }

    // --- territories -----------------------------------------------------
    match /territories/{territoryId} {
      allow read: if isSignedIn();
      allow write: if isManagerOrAdmin();
    }

    // --- leads -----------------------------------------------------------
    // Reps can read/write leads assigned to them; managers/admins see all.
    match /leads/{leadId} {
      allow read: if isSignedIn() &&
        (isManagerOrAdmin() || resource.data.assignedTo == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn() &&
        (isManagerOrAdmin() || resource.data.assignedTo == request.auth.uid);
      allow delete: if isManagerOrAdmin();
    }

    // --- lookups (audit log of homeowner lookups) ------------------------
    match /lookups/{lookupId} {
      allow read: if isSignedIn() &&
        (isManagerOrAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
