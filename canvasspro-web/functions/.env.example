# Copy to functions/.env (gitignored). The property-data API key lives ONLY
# here, server-side — never shipped to the browser or the mobile apps.
#
# Provider: RealEstateAPI.com — sign up at https://www.realestateapi.com,
# create an API key, paste it below. PropertyDetail gives owner + property +
# valuation; SkipTrace (optional, extra cost) adds owner phones/emails.
REAL_ESTATE_API_KEY=YOUR_REALESTATEAPI_KEY
REAL_ESTATE_API_URL=https://api.realestateapi.com

# Set to "0" to skip the extra skip-trace call (no phones/emails, lower cost).
REAL_ESTATE_SKIPTRACE=1
