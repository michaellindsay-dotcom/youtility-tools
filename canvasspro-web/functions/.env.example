# Copy to functions/.env (gitignored). API keys live ONLY here, server-side —
# never shipped to the browser or the mobile apps.
#
# Property + owner + permits + purchase date: ATTOM Data
#   Sign up: https://api.developer.attomdata.com  → get an API key
ATTOM_API_KEY=YOUR_ATTOM_KEY
ATTOM_API_URL=https://api.gateway.attomdata.com/propertyapi/v1.0.0

# Owner phones / emails: BatchData skip-tracing
#   Sign up: https://www.batchdata.com → API key (Bearer token)
BATCHDATA_API_KEY=YOUR_BATCHDATA_KEY
BATCHDATA_API_URL=https://api.batchdata.com
# Set to "0" to skip the skip-trace call (no phones/emails, lower cost).
BATCHDATA_SKIPTRACE=1
